  "cpd_risk_target": 0.15,
  "target_adapt_momentum": 0.5,
  "include_ova_gate": true,
  "calibration_banks": [
    {
      "name": "small",
      "fraction": 0.25
    },
    {
      "name": "large",
      "fraction": 1.0
    }
